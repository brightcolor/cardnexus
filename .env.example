# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ─── Database (SQLite) ─────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000

# ─── Stripe (optional – required for paid plans) ───────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_YEARLY=price_...

# ─── PayPal (optional – alternative payment provider) ─────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_PLAN_PRO_MONTHLY=
PAYPAL_PLAN_PRO_YEARLY=
PAYPAL_PLAN_BUSINESS_MONTHLY=
PAYPAL_PLAN_BUSINESS_YEARLY=
PAYPAL_WEBHOOK_ID=
# sandbox | live
PAYPAL_MODE=sandbox

# ─── SMTP / E-Mail ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# true for port 465, false for other ports
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="CardNexus <noreply@example.com>"

# ─── File Uploads ──────────────────────────────────────────────────────────────
# Directory for uploaded avatars / logos (relative to project root)
UPLOAD_DIR=./uploads

# ─── Apple Wallet (optional, not yet enabled) ──────────────────────────────────
# APPLE_CERT_PATH=
# APPLE_KEY_PATH=
# APPLE_TEAM_ID=
# APPLE_PASS_TYPE_ID=

# ─── Google Wallet (optional, not yet enabled) ─────────────────────────────────
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_KEY=
# GOOGLE_ISSUER_ID=
